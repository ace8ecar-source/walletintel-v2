# =============================================
#  WalletIntel v2 — Configuration
# =============================================

# Server
PORT=8000
DEBUG=false

# Cache
CACHE_TTL_HOURS=24

# =============================================
#  RPC Providers (add your free API keys)
#  More providers = more throughput
# =============================================

# Helius (free: 1M credits/mo, 10 RPS)
# Sign up: https://helius.dev
HELIUS_API_KEY=

# Alchemy (free: 300M CU/mo, ~10 RPS)
# Sign up: https://alchemy.com
ALCHEMY_API_KEY=

# Chainstack (free: 3M requests/mo)
# Sign up: https://chainstack.com
CHAINSTACK_URL=

# QuickNode (free tier available)
# Sign up: https://quicknode.com
QUICKNODE_URL=

# Solana public endpoint is always used as fallback (no key needed)

# =============================================
#  Donation wallet (displayed in API responses)
# =============================================
DONATE_ADDRESS=ykq4M8KYzbrJ9dwG9mAcRuQope1arSWVJzyDRJX4MFj
